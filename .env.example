# Xcode AI Proxy Rust 环境变量示例

# ===================
# 内置提供商（按需填写）
# ===================
ZHIPU_API_KEY=
KIMI_API_KEY=
DEEPSEEK_API_KEY=

# ===================
# OpenAI 兼容上游（推荐）
# ===================
# 例如: https://api.deepseek.com/v1 或 https://api.openai.com/v1
OPENAI_COMPAT_API_URL=
OPENAI_COMPAT_API_KEY=
# 逗号分隔模型列表，例如: deepseek-chat,deepseek-reasoner
OPENAI_COMPAT_MODELS=
OPENAI_COMPAT_NAME_PREFIX=OpenAI-Compatible
OPENAI_COMPAT_PROVIDER_NAME=openai_compat

# ===================
# 兼容旧变量名（已支持）
# ===================
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# ===================
# 服务器配置
# ===================
HOST=0.0.0.0
PORT=3000

# ===================
# 重试与超时配置
# ===================
MAX_RETRIES=3
RETRY_DELAY=1000
REQUEST_TIMEOUT=60000
