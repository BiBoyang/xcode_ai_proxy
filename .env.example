# Xcode AI Proxy Rust 环境变量示例

# ===================
# 默认模型（setup 会写入这一组）
# ===================
# 默认模型在 /v1/models 里的 id（建议保留 DefaultModel）
DEFAULT_MODEL_ID=DefaultModel
# 可选：默认模型展示名
DEFAULT_MODEL_NAME=DefaultModel
# 默认模型对应的 OpenAI 兼容配置
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# ===================
# 追加模型（多供应商）
# ===================
# 逗号分隔模型 id；id 仅支持字母/数字/下划线，且不能以数字开头
EXTRA_MODEL_IDS=

# 示例：ModelA
# MODEL_ModelA_BASE_URL=https://api.openai.com/v1
# MODEL_ModelA_API_KEY=sk-xxxx
# MODEL_ModelA_MODEL=gpt-4.1-mini
# MODEL_ModelA_NAME=OpenAI_GPT_4_1_mini
# MODEL_ModelA_PROVIDER=openai

# 示例：ModelB
# MODEL_ModelB_BASE_URL=https://api.moonshot.cn/v1
# MODEL_ModelB_API_KEY=sk-xxxx
# MODEL_ModelB_MODEL=kimi-k2-0711-preview
# MODEL_ModelB_NAME=Kimi_K2
# MODEL_ModelB_PROVIDER=moonshot

# ===================
# 兼容旧格式（可选）
# ===================
OPENAI_COMPAT_API_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODELS=
OPENAI_COMPAT_NAME_PREFIX=OpenAI-Compatible
OPENAI_COMPAT_PROVIDER_NAME=openai_compat

# ===================
# 服务器配置
# ===================
HOST=0.0.0.0
PORT=3000

# ===================
# 重试与超时配置
# ===================
MAX_RETRIES=3
RETRY_DELAY=1000
REQUEST_TIMEOUT=60000
