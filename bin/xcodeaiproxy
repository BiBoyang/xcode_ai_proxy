#!/bin/bash
set -euo pipefail

resolve_script_dir() {
  local src="$1"
  while [ -L "$src" ]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    if [[ "$src" != /* ]]; then
      src="$dir/$src"
    fi
  done
  cd -P "$(dirname "$src")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir "${BASH_SOURCE[0]}")"
DEFAULT_PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
BINARY_NAME="xcode-ai-proxy-rust"

if [ -f "$DEFAULT_PROJECT_DIR/Cargo.toml" ] || [ -x "$DEFAULT_PROJECT_DIR/$BINARY_NAME" ]; then
  PROJECT_DIR="${XCODEAIPROXY_HOME:-$DEFAULT_PROJECT_DIR}"
else
  PROJECT_DIR="${XCODEAIPROXY_HOME:-$HOME/xcode-ai-proxy-rust}"
fi

ENV_FILE="$PROJECT_DIR/.env"
ENV_EXAMPLE_FILE="$PROJECT_DIR/.env.example"
PID_FILE="$HOME/.xcodeaiproxy.pid"
LOG_FILE="$HOME/.xcodeaiproxy.log"

usage() {
  cat <<'EOF'
用法:
  xcodeaiproxy [start|stop|restart|status|logs|setup|run]

说明:
  start    后台启动（默认）
  stop     停止服务
  restart  重启服务
  status   查看运行状态
  logs     查看日志（实时）
  setup    交互式写入 .env
  run      前台运行（占用当前终端）
EOF
}

ensure_project() {
  if [ ! -d "$PROJECT_DIR" ]; then
    echo "❌ 未找到项目目录: $PROJECT_DIR"
    echo "可设置环境变量 XCODEAIPROXY_HOME 指向项目根目录。"
    exit 1
  fi

  if [ ! -f "$PROJECT_DIR/Cargo.toml" ] \
    && [ ! -x "$PROJECT_DIR/$BINARY_NAME" ] \
    && [ ! -x "$PROJECT_DIR/target/release/$BINARY_NAME" ]; then
    echo "❌ 在 $PROJECT_DIR 下既没找到源码（Cargo.toml），也没找到可执行二进制（$BINARY_NAME）"
    echo "可设置环境变量 XCODEAIPROXY_HOME 指向正确目录。"
    exit 1
  fi
}

ensure_env_file() {
  if [ ! -f "$ENV_FILE" ]; then
    if [ -f "$ENV_EXAMPLE_FILE" ]; then
      cp "$ENV_EXAMPLE_FILE" "$ENV_FILE"
    else
      echo "❌ 未找到 $ENV_EXAMPLE_FILE"
      exit 1
    fi
  fi
}

get_env_value() {
  local key="$1"
  if [ ! -f "$ENV_FILE" ]; then
    echo ""
    return
  fi
  awk -F= -v k="$key" '
    /^[[:space:]]*#/ { next }
    {
      current_key=$1
      gsub(/[[:space:]]/, "", current_key)
      if (current_key == k) {
        $1=""
        sub(/^=/, "", $0)
        sub(/^[[:space:]]+/, "", $0)
        sub(/[[:space:]]+$/, "", $0)
        print $0
        exit
      }
    }
  ' "$ENV_FILE"
}

trim_value() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

validate_base_url() {
  local value="$1"
  [ -n "$value" ] || return 1
  if printf '%s' "$value" | grep -q '[[:space:]]'; then
    return 1
  fi
  case "$value" in
    http://*|https://*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

validate_api_key() {
  local value="$1"
  [ -n "$value" ] || return 1
  if printf '%s' "$value" | grep -q '[[:space:]]'; then
    return 1
  fi
  [ "${#value}" -ge 8 ] || return 1
  return 0
}

validate_model() {
  local value="$1"
  [ -n "$value" ] || return 1
  printf '%s' "$value" | grep -Eq '^[A-Za-z0-9][A-Za-z0-9._:/-]*$'
}

validate_model_id() {
  local value="$1"
  [ -n "$value" ] || return 1
  printf '%s' "$value" | grep -Eq '^[A-Za-z_][A-Za-z0-9_]*$'
}

validate_port() {
  local value="$1"
  printf '%s' "$value" | grep -Eq '^[0-9]+$' || return 1
  [ "$value" -ge 1 ] && [ "$value" -le 65535 ]
}

upsert_env_value() {
  local key="$1"
  local value="$2"
  local tmp
  tmp="$(mktemp)"
  awk -F= -v k="$key" -v v="$value" '
    BEGIN { updated = 0 }
    /^[[:space:]]*#/ { print; next }
    {
      current_key=$1
      gsub(/[[:space:]]/, "", current_key)
      if (current_key == k) {
        print k "=" v
        updated = 1
      } else {
        print
      }
    }
    END {
      if (updated == 0) {
        print k "=" v
      }
    }
  ' "$ENV_FILE" >"$tmp"
  mv "$tmp" "$ENV_FILE"
}

resolve_port() {
  if [ -n "${PORT:-}" ]; then
    echo "$PORT"
    return
  fi
  local env_port
  env_port="$(get_env_value PORT)"
  if [ -n "$env_port" ]; then
    echo "$env_port"
    return
  fi
  echo "3000"
}

is_healthy() {
  local port="$1"
  curl -sS -m 2 "http://127.0.0.1:${port}/health" >/dev/null 2>&1
}

is_proxy_cmd() {
  local cmd="$1"
  [[ "$cmd" == *"xcode-ai-proxy-rust"* ]] || [[ "$cmd" == *"cargo run"* ]]
}

find_binary() {
  if [ -n "${XCODEAIPROXY_BIN:-}" ] && [ -x "$XCODEAIPROXY_BIN" ]; then
    echo "$XCODEAIPROXY_BIN"
    return
  fi

  if [ -x "$PROJECT_DIR/$BINARY_NAME" ]; then
    echo "$PROJECT_DIR/$BINARY_NAME"
    return
  fi

  if [ -x "$PROJECT_DIR/target/release/$BINARY_NAME" ]; then
    echo "$PROJECT_DIR/target/release/$BINARY_NAME"
    return
  fi
}

setup_cmd() {
  ensure_project
  ensure_env_file

  local current_default_model_id current_base current_key current_model current_port
  local default_base default_model default_port
  current_default_model_id="$(get_env_value DEFAULT_MODEL_ID)"
  current_base="$(get_env_value OPENAI_BASE_URL)"
  current_key="$(get_env_value OPENAI_API_KEY)"
  current_model="$(get_env_value OPENAI_MODEL)"
  current_port="$(get_env_value PORT)"

  [ -z "$current_default_model_id" ] && current_default_model_id="DefaultModel"
  if ! validate_model_id "$current_default_model_id"; then
    current_default_model_id="DefaultModel"
  fi
  default_base="https://api.openai.com/v1"
  default_model="gpt-4.1-mini"
  default_port="3000"

  local input

  echo "=== xcodeaiproxy setup ==="
  echo "默认模型 ID: ${current_default_model_id}（可在 .env 修改 DEFAULT_MODEL_ID）"
  while true; do
    echo
    echo "OPENAI_BASE_URL（OpenAI 兼容接口地址）"
    if [ -n "$current_base" ]; then
      echo "当前值: $current_base"
      echo "示例:   $default_base"
      read -r -p "请输入新值（回车保留当前值）: " input
    else
      echo "当前值: 未设置"
      echo "示例:   $default_base"
      read -r -p "请输入值（回车使用默认值）: " input
    fi

    input="$(trim_value "$input")"
    if [ -z "$input" ]; then
      if [ -n "$current_base" ]; then
        input="$current_base"
      else
        input="$default_base"
      fi
    fi

    if validate_base_url "$input"; then
      current_base="$input"
      break
    fi

    echo "❌ OPENAI_BASE_URL 格式不正确。"
    echo "   对策: 必须以 http:// 或 https:// 开头，且不能包含空格。"
    echo "   示例: https://api.openai.com/v1"
  done

  while true; do
    echo
    echo "OPENAI_API_KEY（上游密钥）"
    if [ -n "$current_key" ]; then
      echo "当前值: 已设置（已隐藏）"
      read -r -p "请输入新值（回车保留当前值）: " input
      input="$(trim_value "$input")"
      [ -z "$input" ] && input="$current_key"
    else
      echo "当前值: 未设置"
      read -r -p "请输入值（必填）: " input
      input="$(trim_value "$input")"
    fi

    if validate_api_key "$input"; then
      current_key="$input"
      break
    fi

    echo "❌ OPENAI_API_KEY 格式不正确。"
    echo "   对策: 不能为空、不能有空格、长度至少 8。"
  done

  while true; do
    echo
    echo "OPENAI_MODEL（调用模型名）"
    if [ -n "$current_model" ]; then
      echo "当前值: $current_model"
      echo "示例:   $default_model"
      read -r -p "请输入新值（回车保留当前值）: " input
    else
      echo "当前值: 未设置"
      echo "示例:   $default_model"
      read -r -p "请输入值（回车使用默认值）: " input
    fi

    input="$(trim_value "$input")"
    if [ -z "$input" ]; then
      if [ -n "$current_model" ]; then
        input="$current_model"
      else
        input="$default_model"
      fi
    fi

    if validate_model "$input"; then
      current_model="$input"
      break
    fi

    echo "❌ OPENAI_MODEL 格式不正确。"
    echo "   对策: 仅允许字母、数字、点、下划线、短横线、冒号、斜杠。"
    echo "   示例: gpt-4.1-mini 或 o3-mini"
  done

  while true; do
    echo
    echo "PORT（本地监听端口）"
    if [ -n "$current_port" ]; then
      echo "当前值: $current_port"
      echo "默认值: $default_port"
      read -r -p "请输入端口（回车保留当前值）: " input
    else
      echo "当前值: 未设置"
      echo "默认值: $default_port"
      read -r -p "请输入端口（回车使用默认值）: " input
    fi

    input="$(trim_value "$input")"
    if [ -z "$input" ]; then
      if [ -n "$current_port" ]; then
        input="$current_port"
      else
        input="$default_port"
      fi
    fi

    if validate_port "$input"; then
      current_port="$input"
      break
    fi

    echo "❌ PORT 格式不正确。"
    echo "   对策: 请输入 1-65535 的数字。"
  done

  upsert_env_value DEFAULT_MODEL_ID "$current_default_model_id"
  upsert_env_value OPENAI_BASE_URL "$current_base"
  upsert_env_value OPENAI_API_KEY "$current_key"
  upsert_env_value OPENAI_MODEL "$current_model"
  upsert_env_value PORT "$current_port"

  echo "✅ 配置已写入: $ENV_FILE"
  echo "ℹ️ 如需多供应商模型，可在 .env 里追加 EXTRA_MODEL_IDS 与 MODEL_<ID>_* 配置。"
}

start_cmd() {
  ensure_project
  ensure_env_file

  local port base key model binary_path
  port="$(resolve_port)"
  base="$(get_env_value OPENAI_BASE_URL)"
  key="$(get_env_value OPENAI_API_KEY)"
  model="$(get_env_value OPENAI_MODEL)"
  binary_path="$(find_binary || true)"

  if [ -z "$base" ] || [ -z "$key" ] || [ -z "$model" ]; then
    echo "⚠️ 配置不完整，请先执行: xcodeaiproxy setup"
    exit 1
  fi

  if ! validate_base_url "$base"; then
    echo "❌ OPENAI_BASE_URL 格式不正确: $base"
    echo "对策: 执行 xcodeaiproxy setup 重新配置。"
    exit 1
  fi

  if ! validate_api_key "$key"; then
    echo "❌ OPENAI_API_KEY 格式不正确（不能为空、不能有空格、长度至少 8）。"
    echo "对策: 执行 xcodeaiproxy setup 重新配置。"
    exit 1
  fi

  if ! validate_model "$model"; then
    echo "❌ OPENAI_MODEL 格式不正确: $model"
    echo "对策: 执行 xcodeaiproxy setup 重新配置。"
    exit 1
  fi

  if ! validate_port "$port"; then
    echo "❌ PORT 格式不正确: $port"
    echo "对策: 执行 xcodeaiproxy setup 重新配置。"
    exit 1
  fi

  if is_healthy "$port"; then
    echo "ℹ️ xcodeaiproxy 已在运行 (port=$port)"
    exit 0
  fi

  echo "🚀 后台启动 xcodeaiproxy (port=$port)"
  if [ -n "$binary_path" ]; then
    (
      cd "$PROJECT_DIR"
      nohup env PORT="$port" "$binary_path" >"$LOG_FILE" 2>&1 &
      echo $! >"$PID_FILE"
    )
  else
    if ! command -v cargo >/dev/null 2>&1; then
      echo "❌ 未找到可执行二进制，也未安装 cargo。"
      echo "请先执行 cargo build --release，或安装 Rust 工具链。"
      exit 1
    fi
    (
      cd "$PROJECT_DIR"
      nohup env PORT="$port" cargo run >"$LOG_FILE" 2>&1 &
      echo $! >"$PID_FILE"
    )
  fi

  local ok=0
  for _ in {1..50}; do
    if is_healthy "$port"; then
      ok=1
      break
    fi
    sleep 0.2
  done

  if [ "$ok" -eq 1 ]; then
    echo "✅ 启动成功: http://127.0.0.1:$port"
    echo "日志文件: $LOG_FILE"
    exit 0
  fi

  echo "❌ 启动失败，最近日志:"
  tail -n 50 "$LOG_FILE" 2>/dev/null || true
  exit 1
}

stop_cmd() {
  ensure_project
  ensure_env_file
  local port stop_script
  port="$(resolve_port)"
  stop_script="$SCRIPT_DIR/xcodeaiproxy-stop"

  if [ -x "$stop_script" ]; then
    PORT="$port" "$stop_script" "$@"
  elif command -v xcodeaiproxy-stop >/dev/null 2>&1; then
    PORT="$port" xcodeaiproxy-stop "$@"
  else
    echo "❌ 未找到 xcodeaiproxy-stop"
    exit 1
  fi

  if [ -f "$PID_FILE" ]; then
    rm -f "$PID_FILE"
  fi
}

status_cmd() {
  ensure_project
  ensure_env_file
  local port healthy status
  local pid_file_pid pid_file_state
  local listening_pids proxy_pids
  port="$(resolve_port)"

  healthy=0
  if is_healthy "$port"; then
    healthy=1
  fi

  listening_pids=""
  proxy_pids=""
  if command -v lsof >/dev/null 2>&1; then
    local pid cmd
    while IFS= read -r pid; do
      [ -z "$pid" ] && continue

      if [ -n "$listening_pids" ]; then
        listening_pids="$listening_pids $pid"
      else
        listening_pids="$pid"
      fi

      cmd="$(ps -p "$pid" -o command= 2>/dev/null || true)"
      if is_proxy_cmd "$cmd"; then
        if [ -n "$proxy_pids" ]; then
          proxy_pids="$proxy_pids $pid"
        else
          proxy_pids="$pid"
        fi
      fi
    done < <(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)
  fi

  pid_file_pid=""
  pid_file_state="missing"
  if [ -f "$PID_FILE" ]; then
    pid_file_pid="$(head -n 1 "$PID_FILE" | tr -d '[:space:]')"
    if [[ "$pid_file_pid" =~ ^[0-9]+$ ]] && kill -0 "$pid_file_pid" 2>/dev/null; then
      pid_file_state="alive"
    elif [[ "$pid_file_pid" =~ ^[0-9]+$ ]]; then
      pid_file_state="stale"
    else
      pid_file_state="invalid"
    fi
  fi

  status="stopped"
  if [ "$healthy" -eq 1 ] || [ -n "$proxy_pids" ]; then
    status="running"
  fi

  if [ "$status" = "running" ]; then
    echo "✅ 状态: running"
  else
    echo "ℹ️ 状态: stopped"
  fi

  echo "端口: $port"
  if [ "$healthy" -eq 1 ]; then
    echo "健康检查: ok"
  else
    echo "健康检查: fail"
  fi
  echo "访问地址: http://127.0.0.1:$port"

  if [ -n "$proxy_pids" ]; then
    echo "代理进程 PID: $proxy_pids"
  elif [ -n "$listening_pids" ]; then
    echo "监听进程 PID: $listening_pids (非 xcode-ai-proxy-rust)"
  else
    echo "监听进程: 无"
  fi

  case "$pid_file_state" in
    alive)
      echo "PID 文件: $PID_FILE (有效: $pid_file_pid)"
      ;;
    stale)
      echo "PID 文件: $PID_FILE (已失效: $pid_file_pid)"
      ;;
    invalid)
      echo "PID 文件: $PID_FILE (内容无效)"
      ;;
    *)
      echo "PID 文件: $PID_FILE (不存在)"
      ;;
  esac

  echo "配置文件: $ENV_FILE"
  echo "日志文件: $LOG_FILE"

  if [ "$status" = "running" ]; then
    echo "停止命令: xcodeaiproxy-stop"
  fi
}

logs_cmd() {
  if [ ! -f "$LOG_FILE" ]; then
    echo "ℹ️ 暂无日志: $LOG_FILE"
    exit 0
  fi
  tail -n 100 -f "$LOG_FILE"
}

run_cmd() {
  ensure_project
  ensure_env_file
  local binary_path
  binary_path="$(find_binary || true)"
  cd "$PROJECT_DIR"
  if [ -n "$binary_path" ]; then
    exec env PORT="$(resolve_port)" "$binary_path"
  fi

  if [ -x "./start_rust.sh" ]; then
    exec ./start_rust.sh
  fi

  if command -v cargo >/dev/null 2>&1; then
    exec cargo run
  fi

  echo "❌ 无法前台运行：未找到二进制、start_rust.sh 或 cargo。"
  exit 1
}

COMMAND="${1:-start}"
if [ $# -gt 0 ]; then
  shift
fi

case "$COMMAND" in
  start)
    start_cmd "$@"
    ;;
  stop)
    stop_cmd "$@"
    ;;
  restart)
    stop_cmd "$@" || true
    start_cmd "$@"
    ;;
  status)
    status_cmd "$@"
    ;;
  logs)
    logs_cmd "$@"
    ;;
  setup)
    setup_cmd "$@"
    ;;
  run)
    run_cmd "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
