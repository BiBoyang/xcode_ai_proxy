#!/bin/bash
set -euo pipefail

resolve_script_dir() {
  local src="$1"
  while [ -L "$src" ]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    if [[ "$src" != /* ]]; then
      src="$dir/$src"
    fi
  done
  cd -P "$(dirname "$src")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir "${BASH_SOURCE[0]}")"
DEFAULT_PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
BINARY_NAME="xcode-ai-proxy-rust"

if [ -f "$DEFAULT_PROJECT_DIR/Cargo.toml" ] || [ -x "$DEFAULT_PROJECT_DIR/$BINARY_NAME" ]; then
  PROJECT_DIR="${XCODEAIPROXY_HOME:-$DEFAULT_PROJECT_DIR}"
else
  PROJECT_DIR="${XCODEAIPROXY_HOME:-$HOME/xcode-ai-proxy-rust}"
fi

ENV_FILE="$PROJECT_DIR/.env"
ENV_EXAMPLE_FILE="$PROJECT_DIR/.env.example"
PID_FILE="$HOME/.xcodeaiproxy.pid"
LOG_FILE="$HOME/.xcodeaiproxy.log"

usage() {
  cat <<'EOF'
用法:
  xcodeaiproxy [start|stop|restart|status|logs|setup|run|models|use-model|doctor]

说明:
  start    后台启动（默认）
  stop     停止服务
  restart  重启服务
  status   查看运行状态
  logs     查看日志（实时）
  setup    交互式写入 .env
  run      前台运行（占用当前终端）
  models   查看模型列表与当前默认模型
  use-model <模型ID>  切换默认模型来源（写入 OPENAI_*）
  doctor   一键体检配置与运行环境
EOF
}

ensure_project() {
  if [ ! -d "$PROJECT_DIR" ]; then
    echo "❌ 未找到项目目录: $PROJECT_DIR"
    echo "可设置环境变量 XCODEAIPROXY_HOME 指向项目根目录。"
    exit 1
  fi

  if [ ! -f "$PROJECT_DIR/Cargo.toml" ] \
    && [ ! -x "$PROJECT_DIR/$BINARY_NAME" ] \
    && [ ! -x "$PROJECT_DIR/target/release/$BINARY_NAME" ]; then
    echo "❌ 在 $PROJECT_DIR 下既没找到源码（Cargo.toml），也没找到可执行二进制（$BINARY_NAME）"
    echo "可设置环境变量 XCODEAIPROXY_HOME 指向正确目录。"
    exit 1
  fi
}

ensure_env_file() {
  if [ ! -f "$ENV_FILE" ]; then
    if [ -f "$ENV_EXAMPLE_FILE" ]; then
      cp "$ENV_EXAMPLE_FILE" "$ENV_FILE"
    else
      echo "❌ 未找到 $ENV_EXAMPLE_FILE"
      exit 1
    fi
  fi
}

get_env_value() {
  local key="$1"
  if [ ! -f "$ENV_FILE" ]; then
    echo ""
    return
  fi
  awk -F= -v k="$key" '
    /^[[:space:]]*#/ { next }
    {
      current_key=$1
      gsub(/[[:space:]]/, "", current_key)
      if (current_key == k) {
        $1=""
        sub(/^=/, "", $0)
        sub(/^[[:space:]]+/, "", $0)
        sub(/[[:space:]]+$/, "", $0)
        print $0
        exit
      }
    }
  ' "$ENV_FILE"
}

find_case_mismatch_key() {
  local key="$1"
  awk -F= -v k="$key" '
    /^[[:space:]]*#/ { next }
    {
      current_key=$1
      gsub(/[[:space:]]/, "", current_key)
      if (tolower(current_key) == tolower(k) && current_key != k) {
        print current_key
        exit
      }
    }
  ' "$ENV_FILE"
}

trim_value() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

validate_base_url() {
  local value="$1"
  [ -n "$value" ] || return 1
  if printf '%s' "$value" | grep -q '[[:space:]]'; then
    return 1
  fi
  case "$value" in
    http://*|https://*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

validate_api_key() {
  local value="$1"
  [ -n "$value" ] || return 1
  if printf '%s' "$value" | grep -q '[[:space:]]'; then
    return 1
  fi
  [ "${#value}" -ge 8 ] || return 1
  return 0
}

validate_model() {
  local value="$1"
  [ -n "$value" ] || return 1
  printf '%s' "$value" | grep -Eq '^[A-Za-z0-9][A-Za-z0-9._:/-]*$'
}

validate_model_id() {
  local value="$1"
  [ -n "$value" ] || return 1
  printf '%s' "$value" | grep -Eq '^[A-Za-z_][A-Za-z0-9_]*$'
}

validate_port() {
  local value="$1"
  printf '%s' "$value" | grep -Eq '^[0-9]+$' || return 1
  [ "$value" -ge 1 ] && [ "$value" -le 65535 ]
}

upsert_env_value() {
  local key="$1"
  local value="$2"
  local tmp
  tmp="$(mktemp)"
  awk -F= -v k="$key" -v v="$value" '
    BEGIN { updated = 0 }
    /^[[:space:]]*#/ { print; next }
    {
      current_key=$1
      gsub(/[[:space:]]/, "", current_key)
      if (current_key == k) {
        print k "=" v
        updated = 1
      } else {
        print
      }
    }
    END {
      if (updated == 0) {
        print k "=" v
      }
    }
  ' "$ENV_FILE" >"$tmp"
  mv "$tmp" "$ENV_FILE"
}

resolve_port() {
  if [ -n "${PORT:-}" ]; then
    echo "$PORT"
    return
  fi
  local env_port
  env_port="$(get_env_value PORT)"
  if [ -n "$env_port" ]; then
    echo "$env_port"
    return
  fi
  echo "3000"
}

is_healthy() {
  local port="$1"
  curl -sS -m 2 "http://127.0.0.1:${port}/health" >/dev/null 2>&1
}

is_proxy_cmd() {
  local cmd="$1"
  [[ "$cmd" == *"xcode-ai-proxy-rust"* ]] || [[ "$cmd" == *"cargo run"* ]]
}

resolve_default_model_id() {
  local default_id
  default_id="$(get_env_value DEFAULT_MODEL_ID)"
  if [ -z "$default_id" ] || ! validate_model_id "$default_id"; then
    default_id="DefaultModel"
  fi
  echo "$default_id"
}

parse_extra_model_ids() {
  local raw
  raw="$(get_env_value EXTRA_MODEL_IDS)"
  [ -n "$raw" ] || return 0

  printf '%s\n' "$raw" | awk -F',' '
    {
      for (i = 1; i <= NF; i++) {
        item=$i
        gsub(/^[[:space:]]+/, "", item)
        gsub(/[[:space:]]+$/, "", item)
        if (item != "") {
          print item
        }
      }
    }
  '
}

extra_model_exists() {
  local target="$1"
  local id
  while IFS= read -r id; do
    [ "$id" = "$target" ] && return 0
  done < <(parse_extra_model_ids)
  return 1
}

show_models_cmd() {
  ensure_project
  ensure_env_file

  local default_id default_name current_base current_key current_model
  default_id="$(resolve_default_model_id)"
  default_name="$(get_env_value DEFAULT_MODEL_NAME)"
  [ -z "$default_name" ] && default_name="Default Model"
  current_base="$(get_env_value OPENAI_BASE_URL)"
  current_key="$(get_env_value OPENAI_API_KEY)"
  current_model="$(get_env_value OPENAI_MODEL)"

  echo "=== 当前默认模型（Xcode 默认走这个） ==="
  echo "ID: $default_id"
  echo "Name: $default_name"
  if [ -n "$current_model" ]; then
    echo "Model: $current_model"
  else
    echo "Model: （未设置）"
  fi
  if [ -n "$current_base" ]; then
    echo "Base URL: $current_base"
  else
    echo "Base URL: （未设置）"
  fi
  if [ -n "$current_key" ]; then
    echo "API Key: 已设置（已隐藏）"
  else
    echo "API Key: 未设置"
  fi

  echo
  echo "=== 可切换模型（来自 EXTRA_MODEL_IDS） ==="
  local id count
  count=0
  while IFS= read -r id; do
    [ -z "$id" ] && continue
    count=$((count + 1))

    local base_key api_key_key model_key name_key
    local base api_key model name active
    base_key="MODEL_${id}_BASE_URL"
    api_key_key="MODEL_${id}_API_KEY"
    model_key="MODEL_${id}_MODEL"
    name_key="MODEL_${id}_NAME"

    base="$(get_env_value "$base_key")"
    api_key="$(get_env_value "$api_key_key")"
    model="$(get_env_value "$model_key")"
    name="$(get_env_value "$name_key")"
    [ -z "$name" ] && name="$id"

    if [ -z "$base" ] || [ -z "$api_key" ] || [ -z "$model" ]; then
      echo "- $id: ❌ 配置不完整（需要 $base_key / $api_key_key / $model_key）"
      continue
    fi

    active=""
    if [ "$base" = "$current_base" ] && [ "$api_key" = "$current_key" ] && [ "$model" = "$current_model" ]; then
      active="（当前已启用）"
    fi
    echo "- $id: $name -> $model @ $base $active"
  done < <(parse_extra_model_ids)

  if [ "$count" -eq 0 ]; then
    echo "（未配置）可在 .env 添加 EXTRA_MODEL_IDS=ModelA,ModelB"
  fi
}

use_model_cmd() {
  ensure_project
  ensure_env_file

  local target_id="$1"
  if [ -z "$target_id" ]; then
    echo "用法: xcodeaiproxy use-model <模型ID>"
    exit 1
  fi

  if ! validate_model_id "$target_id"; then
    echo "❌ 模型 ID 格式不正确: $target_id"
    echo "对策: 仅支持字母、数字、下划线，且不能以数字开头。"
    exit 1
  fi

  if ! extra_model_exists "$target_id"; then
    local default_id
    default_id="$(resolve_default_model_id)"
    if [ "$target_id" = "$default_id" ]; then
      echo "ℹ️ 当前默认模型 ID 就是: $default_id"
      exit 0
    fi
    echo "❌ 未在 EXTRA_MODEL_IDS 中找到模型: $target_id"
    echo "请先执行: xcodeaiproxy models 查看可用模型。"
    exit 1
  fi

  local base_key api_key_key model_key name_key
  local base api_key model name
  base_key="MODEL_${target_id}_BASE_URL"
  api_key_key="MODEL_${target_id}_API_KEY"
  model_key="MODEL_${target_id}_MODEL"
  name_key="MODEL_${target_id}_NAME"

  base="$(get_env_value "$base_key")"
  api_key="$(get_env_value "$api_key_key")"
  model="$(get_env_value "$model_key")"
  name="$(get_env_value "$name_key")"

  if [ -z "$base" ] || [ -z "$api_key" ] || [ -z "$model" ]; then
    echo "❌ 模型 $target_id 配置不完整。"
    echo "请补全: $base_key / $api_key_key / $model_key"
    exit 1
  fi

  if ! validate_base_url "$base"; then
    echo "❌ $base_key 格式不正确: $base"
    exit 1
  fi
  if ! validate_api_key "$api_key"; then
    echo "❌ $api_key_key 格式不正确。"
    exit 1
  fi
  if ! validate_model "$model"; then
    echo "❌ $model_key 格式不正确: $model"
    exit 1
  fi

  upsert_env_value OPENAI_BASE_URL "$base"
  upsert_env_value OPENAI_API_KEY "$api_key"
  upsert_env_value OPENAI_MODEL "$model"
  upsert_env_value DEFAULT_MODEL_NAME "$target_id"

  echo "✅ 已切换默认模型来源到: $target_id"
  echo "   OPENAI_MODEL=$model"
  echo "   OPENAI_BASE_URL=$base"

  local port
  port="$(resolve_port)"
  if is_healthy "$port"; then
    echo "ℹ️ 服务正在运行，建议执行: xcodeaiproxy restart"
  fi
}

doctor_cmd() {
  ensure_project
  ensure_env_file

  local pass_count warn_count fail_count
  pass_count=0
  warn_count=0
  fail_count=0

  doctor_emit() {
    local level="$1"
    local message="$2"
    case "$level" in
      ok)
        echo "✅ $message"
        pass_count=$((pass_count + 1))
        ;;
      warn)
        echo "⚠️ $message"
        warn_count=$((warn_count + 1))
        ;;
      fail)
        echo "❌ $message"
        fail_count=$((fail_count + 1))
        ;;
    esac
  }

  local default_id base key model
  local raw_extra_ids extra_count invalid_extra_count
  local port_checked
  local listening_pids proxy_pids
  local bad_space_lines
  local extra_ids_case_mismatch
  local model_key_ids_any_case

  echo "=== xcodeaiproxy doctor ==="
  echo "项目目录: $PROJECT_DIR"
  echo "配置文件: $ENV_FILE"
  echo

  default_id="$(get_env_value DEFAULT_MODEL_ID)"
  if [ -z "$default_id" ]; then
    doctor_emit warn "DEFAULT_MODEL_ID 未设置，将按 DefaultModel 兜底。"
  elif validate_model_id "$default_id"; then
    doctor_emit ok "DEFAULT_MODEL_ID 格式正确: ${default_id}"
  else
    doctor_emit fail "DEFAULT_MODEL_ID 格式错误: ${default_id}（仅支持字母/数字/下划线，且不能以数字开头）"
  fi

  base="$(get_env_value OPENAI_BASE_URL)"
  if validate_base_url "$base"; then
    doctor_emit ok "OPENAI_BASE_URL 格式正确"
  elif [ -z "$base" ]; then
    local base_case_mismatch
    base_case_mismatch="$(find_case_mismatch_key OPENAI_BASE_URL)"
    if [ -n "$base_case_mismatch" ]; then
      doctor_emit fail "键名大小写错误: ${base_case_mismatch}，应为 OPENAI_BASE_URL"
    else
      doctor_emit fail "OPENAI_BASE_URL 未配置。对策: 执行 xcodeaiproxy setup。"
    fi
  else
    doctor_emit fail "OPENAI_BASE_URL 格式错误。对策: 必须以 http:// 或 https:// 开头，且不能有空格。"
  fi

  key="$(get_env_value OPENAI_API_KEY)"
  if validate_api_key "$key"; then
    doctor_emit ok "OPENAI_API_KEY 格式正确"
  elif [ -z "$key" ]; then
    local key_case_mismatch
    key_case_mismatch="$(find_case_mismatch_key OPENAI_API_KEY)"
    if [ -n "$key_case_mismatch" ]; then
      doctor_emit fail "键名大小写错误: ${key_case_mismatch}，应为 OPENAI_API_KEY"
    else
      doctor_emit fail "OPENAI_API_KEY 未配置。对策: 执行 xcodeaiproxy setup。"
    fi
  else
    doctor_emit fail "OPENAI_API_KEY 格式错误。对策: 不能为空、不能有空格、长度至少 8。"
  fi

  model="$(get_env_value OPENAI_MODEL)"
  if validate_model "$model"; then
    doctor_emit ok "OPENAI_MODEL 格式正确: ${model}"
  elif [ -z "$model" ]; then
    local model_case_mismatch
    model_case_mismatch="$(find_case_mismatch_key OPENAI_MODEL)"
    if [ -n "$model_case_mismatch" ]; then
      doctor_emit fail "键名大小写错误: ${model_case_mismatch}，应为 OPENAI_MODEL"
    else
      doctor_emit fail "OPENAI_MODEL 未配置。对策: 执行 xcodeaiproxy setup。"
    fi
  else
    doctor_emit fail "OPENAI_MODEL 格式错误: ${model}（仅允许字母、数字、点、下划线、短横线、冒号、斜杠）"
  fi

  raw_extra_ids="$(get_env_value EXTRA_MODEL_IDS)"
  extra_ids_case_mismatch="$(find_case_mismatch_key EXTRA_MODEL_IDS)"
  model_key_ids_any_case="$(awk '
    /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
    index($0, "=") == 0 { next }
    {
      line=$0
      sub(/^[[:space:]]+/, "", line)
      key=line
      sub(/=.*/, "", key)
      low=tolower(key)
      gsub(/[[:space:]]/, "", low)
      if (low ~ /^model_[a-z0-9_]+_(base_url|api_key|model|name|provider)$/) {
        id=low
        sub(/^model_/, "", id)
        sub(/_(base_url|api_key|model|name|provider)$/, "", id)
        seen[id]=1
      }
    }
    END {
      for (id in seen) {
        print id
      }
    }
  ' "$ENV_FILE" | sort)"

  if [ -z "$raw_extra_ids" ]; then
    if [ -n "$extra_ids_case_mismatch" ]; then
      doctor_emit fail "键名大小写错误: ${extra_ids_case_mismatch}，应为 EXTRA_MODEL_IDS"
    elif [ -n "$model_key_ids_any_case" ]; then
      doctor_emit fail "检测到 MODEL_<ID>_* 配置，但 EXTRA_MODEL_IDS 为空。"
      echo "  检测到的模型 ID（忽略大小写）:"
      while IFS= read -r lower_id; do
        [ -z "$lower_id" ] && continue
        echo "  - $lower_id"
      done <<<"$model_key_ids_any_case"
      echo "  对策: 在 .env 增加 EXTRA_MODEL_IDS=ModelA,ModelB（与 MODEL_<ID>_* 里的 ID 保持一致）。"
    else
      doctor_emit warn "未配置 EXTRA_MODEL_IDS（可选，多模型时再加）。"
    fi
  else
    doctor_emit ok "已配置 EXTRA_MODEL_IDS: ${raw_extra_ids}"
  fi

  extra_count=0
  invalid_extra_count=0
  while IFS= read -r model_id; do
    [ -z "$model_id" ] && continue
    extra_count=$((extra_count + 1))

    if ! validate_model_id "$model_id"; then
      doctor_emit fail "EXTRA_MODEL_IDS 包含非法模型 ID: ${model_id}"
      invalid_extra_count=$((invalid_extra_count + 1))
      continue
    fi

    local extra_base extra_key extra_model extra_name
    local extra_base_key extra_key_key extra_model_key extra_name_key
    extra_base_key="MODEL_${model_id}_BASE_URL"
    extra_key_key="MODEL_${model_id}_API_KEY"
    extra_model_key="MODEL_${model_id}_MODEL"
    extra_name_key="MODEL_${model_id}_NAME"

    extra_base="$(get_env_value "$extra_base_key")"
    extra_key="$(get_env_value "$extra_key_key")"
    extra_model="$(get_env_value "$extra_model_key")"
    extra_name="$(get_env_value "$extra_name_key")"

    local missing_required
    missing_required=0

    if [ -z "$extra_base" ]; then
      local extra_base_case_mismatch
      extra_base_case_mismatch="$(find_case_mismatch_key "$extra_base_key")"
      if [ -n "$extra_base_case_mismatch" ]; then
        doctor_emit fail "模型 ${model_id} 键名大小写错误: ${extra_base_case_mismatch}，应为 ${extra_base_key}"
      else
        doctor_emit fail "模型 ${model_id} 缺少 ${extra_base_key}"
      fi
      missing_required=1
    fi

    if [ -z "$extra_key" ]; then
      local extra_key_case_mismatch
      extra_key_case_mismatch="$(find_case_mismatch_key "$extra_key_key")"
      if [ -n "$extra_key_case_mismatch" ]; then
        doctor_emit fail "模型 ${model_id} 键名大小写错误: ${extra_key_case_mismatch}，应为 ${extra_key_key}"
      else
        doctor_emit fail "模型 ${model_id} 缺少 ${extra_key_key}"
      fi
      missing_required=1
    fi

    if [ -z "$extra_model" ]; then
      local extra_model_case_mismatch
      extra_model_case_mismatch="$(find_case_mismatch_key "$extra_model_key")"
      if [ -n "$extra_model_case_mismatch" ]; then
        doctor_emit fail "模型 ${model_id} 键名大小写错误: ${extra_model_case_mismatch}，应为 ${extra_model_key}"
      else
        doctor_emit fail "模型 ${model_id} 缺少 ${extra_model_key}"
      fi
      missing_required=1
    fi

    if [ "$missing_required" -eq 1 ]; then
      continue
    fi

    if ! validate_base_url "$extra_base"; then
      doctor_emit fail "${extra_base_key} 格式错误"
    else
      doctor_emit ok "${extra_base_key} 格式正确"
    fi

    if ! validate_api_key "$extra_key"; then
      doctor_emit fail "${extra_key_key} 格式错误"
    else
      doctor_emit ok "${extra_key_key} 格式正确"
    fi

    if ! validate_model "$extra_model"; then
      doctor_emit fail "${extra_model_key} 格式错误: ${extra_model}"
    else
      doctor_emit ok "${extra_model_key} 格式正确: ${extra_model}"
    fi

    if [ -z "$extra_name" ]; then
      local extra_name_case_mismatch
      extra_name_case_mismatch="$(find_case_mismatch_key "$extra_name_key")"
      if [ -n "$extra_name_case_mismatch" ]; then
        doctor_emit warn "模型 ${model_id} 键名大小写可能有误: ${extra_name_case_mismatch}，建议改为 ${extra_name_key}"
      else
        doctor_emit warn "${extra_name_key} 未设置（可选，仅用于显示）"
      fi
    elif printf '%s' "$extra_name" | grep -q '[[:space:]]'; then
      doctor_emit warn "${extra_name_key} 含空格，建议改为无空格或加双引号以避免 dotenv 解析问题"
    else
      doctor_emit ok "${extra_name_key} 已设置"
    fi
  done < <(parse_extra_model_ids)

  if [ -n "$raw_extra_ids" ] && [ "$extra_count" -eq 0 ]; then
    doctor_emit fail "EXTRA_MODEL_IDS 已配置但未解析出有效条目，请检查逗号分隔格式。"
  fi

  if [ "$extra_count" -gt 0 ] && [ "$invalid_extra_count" -eq 0 ]; then
    doctor_emit ok "额外模型 ID 解析完成，共 ${extra_count} 个"
  fi

  bad_space_lines="$(awk '
    /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
    index($0, "=") == 0 { next }
    {
      line=$0
      sub(/^[[:space:]]+/, "", line)
      key=line
      sub(/=.*/, "", key)
      val=line
      sub(/^[^=]*=/, "", val)
      gsub(/^[[:space:]]+/, "", val)
      gsub(/[[:space:]]+$/, "", val)
      if (val ~ /[[:space:]]/) {
        first=substr(val, 1, 1)
        last=substr(val, length(val), 1)
        if (!((first == "\"" && last == "\"") || (first == "\047" && last == "\047"))) {
          printf "  - 行 %d: %s=%s\n", NR, key, val
        }
      }
    }
  ' "$ENV_FILE")"

  if [ -n "$bad_space_lines" ]; then
    doctor_emit fail ".env 检测到未加引号且包含空格的值，可能导致 dotenv 解析中断。"
    echo "$bad_space_lines"
    echo "  对策: 改为无空格（如 DefaultModel），或使用双引号包裹（如 \"Default Model\"）。"
  else
    doctor_emit ok ".env 未发现明显的空格解析风险行"
  fi

  port_checked="$(resolve_port)"
  if validate_port "$port_checked"; then
    doctor_emit ok "PORT 有效: ${port_checked}"
  else
    doctor_emit fail "PORT 格式错误: ${port_checked}（应为 1-65535）"
    port_checked="3000"
  fi

  listening_pids=""
  proxy_pids=""
  if command -v lsof >/dev/null 2>&1; then
    local pid cmd
    while IFS= read -r pid; do
      [ -z "$pid" ] && continue
      cmd="$(ps -p "$pid" -o command= 2>/dev/null || true)"
      if is_proxy_cmd "$cmd"; then
        if [ -n "$proxy_pids" ]; then
          proxy_pids="$proxy_pids $pid"
        else
          proxy_pids="$pid"
        fi
      fi
      if [ -n "$listening_pids" ]; then
        listening_pids="$listening_pids $pid"
      else
        listening_pids="$pid"
      fi
    done < <(lsof -tiTCP:"$port_checked" -sTCP:LISTEN 2>/dev/null || true)
  fi

  if is_healthy "$port_checked"; then
    doctor_emit ok "健康检查通过: http://127.0.0.1:${port_checked}/health"
  else
    if [ -n "$proxy_pids" ]; then
      doctor_emit warn "检测到代理进程 PID=${proxy_pids}，但健康检查失败（可执行 xcodeaiproxy logs 排查）"
    elif [ -n "$listening_pids" ]; then
      doctor_emit warn "端口 ${port_checked} 被其他进程占用（PID=${listening_pids}）"
    else
      doctor_emit warn "服务当前未运行（如需启动执行 xcodeaiproxy start）"
    fi
  fi

  echo
  echo "=== doctor 汇总 ==="
  echo "PASS: $pass_count"
  echo "WARN: $warn_count"
  echo "FAIL: $fail_count"

  if [ "$fail_count" -gt 0 ]; then
    return 1
  fi
  return 0
}

find_binary() {
  if [ -n "${XCODEAIPROXY_BIN:-}" ] && [ -x "$XCODEAIPROXY_BIN" ]; then
    echo "$XCODEAIPROXY_BIN"
    return
  fi

  if [ -x "$PROJECT_DIR/$BINARY_NAME" ]; then
    echo "$PROJECT_DIR/$BINARY_NAME"
    return
  fi

  if [ -x "$PROJECT_DIR/target/release/$BINARY_NAME" ]; then
    echo "$PROJECT_DIR/target/release/$BINARY_NAME"
    return
  fi
}

setup_cmd() {
  ensure_project
  ensure_env_file

  local current_default_model_id current_base current_key current_model current_port
  local default_base default_model default_port
  current_default_model_id="$(get_env_value DEFAULT_MODEL_ID)"
  current_base="$(get_env_value OPENAI_BASE_URL)"
  current_key="$(get_env_value OPENAI_API_KEY)"
  current_model="$(get_env_value OPENAI_MODEL)"
  current_port="$(get_env_value PORT)"

  [ -z "$current_default_model_id" ] && current_default_model_id="DefaultModel"
  if ! validate_model_id "$current_default_model_id"; then
    current_default_model_id="DefaultModel"
  fi
  default_base="https://api.openai.com/v1"
  default_model="gpt-4.1-mini"
  default_port="3000"

  local input

  echo "=== xcodeaiproxy setup ==="
  echo "默认模型 ID: ${current_default_model_id}（可在 .env 修改 DEFAULT_MODEL_ID）"
  while true; do
    echo
    echo "OPENAI_BASE_URL（OpenAI 兼容接口地址）"
    if [ -n "$current_base" ]; then
      echo "当前值: $current_base"
      echo "示例:   $default_base"
      read -r -p "请输入新值（回车保留当前值）: " input
    else
      echo "当前值: 未设置"
      echo "示例:   $default_base"
      read -r -p "请输入值（回车使用默认值）: " input
    fi

    input="$(trim_value "$input")"
    if [ -z "$input" ]; then
      if [ -n "$current_base" ]; then
        input="$current_base"
      else
        input="$default_base"
      fi
    fi

    if validate_base_url "$input"; then
      current_base="$input"
      break
    fi

    echo "❌ OPENAI_BASE_URL 格式不正确。"
    echo "   对策: 必须以 http:// 或 https:// 开头，且不能包含空格。"
    echo "   示例: https://api.openai.com/v1"
  done

  while true; do
    echo
    echo "OPENAI_API_KEY（上游密钥）"
    if [ -n "$current_key" ]; then
      echo "当前值: 已设置（已隐藏）"
      read -r -p "请输入新值（回车保留当前值）: " input
      input="$(trim_value "$input")"
      [ -z "$input" ] && input="$current_key"
    else
      echo "当前值: 未设置"
      read -r -p "请输入值（必填）: " input
      input="$(trim_value "$input")"
    fi

    if validate_api_key "$input"; then
      current_key="$input"
      break
    fi

    echo "❌ OPENAI_API_KEY 格式不正确。"
    echo "   对策: 不能为空、不能有空格、长度至少 8。"
  done

  while true; do
    echo
    echo "OPENAI_MODEL（调用模型名）"
    if [ -n "$current_model" ]; then
      echo "当前值: $current_model"
      echo "示例:   $default_model"
      read -r -p "请输入新值（回车保留当前值）: " input
    else
      echo "当前值: 未设置"
      echo "示例:   $default_model"
      read -r -p "请输入值（回车使用默认值）: " input
    fi

    input="$(trim_value "$input")"
    if [ -z "$input" ]; then
      if [ -n "$current_model" ]; then
        input="$current_model"
      else
        input="$default_model"
      fi
    fi

    if validate_model "$input"; then
      current_model="$input"
      break
    fi

    echo "❌ OPENAI_MODEL 格式不正确。"
    echo "   对策: 仅允许字母、数字、点、下划线、短横线、冒号、斜杠。"
    echo "   示例: gpt-4.1-mini 或 o3-mini"
  done

  while true; do
    echo
    echo "PORT（本地监听端口）"
    if [ -n "$current_port" ]; then
      echo "当前值: $current_port"
      echo "默认值: $default_port"
      read -r -p "请输入端口（回车保留当前值）: " input
    else
      echo "当前值: 未设置"
      echo "默认值: $default_port"
      read -r -p "请输入端口（回车使用默认值）: " input
    fi

    input="$(trim_value "$input")"
    if [ -z "$input" ]; then
      if [ -n "$current_port" ]; then
        input="$current_port"
      else
        input="$default_port"
      fi
    fi

    if validate_port "$input"; then
      current_port="$input"
      break
    fi

    echo "❌ PORT 格式不正确。"
    echo "   对策: 请输入 1-65535 的数字。"
  done

  upsert_env_value DEFAULT_MODEL_ID "$current_default_model_id"
  upsert_env_value OPENAI_BASE_URL "$current_base"
  upsert_env_value OPENAI_API_KEY "$current_key"
  upsert_env_value OPENAI_MODEL "$current_model"
  upsert_env_value PORT "$current_port"

  echo "✅ 配置已写入: $ENV_FILE"
  echo "ℹ️ 如需多供应商模型，可在 .env 里追加 EXTRA_MODEL_IDS 与 MODEL_<ID>_* 配置。"
}

start_cmd() {
  ensure_project
  ensure_env_file

  local port base key model binary_path
  port="$(resolve_port)"
  base="$(get_env_value OPENAI_BASE_URL)"
  key="$(get_env_value OPENAI_API_KEY)"
  model="$(get_env_value OPENAI_MODEL)"
  binary_path="$(find_binary || true)"

  if [ -z "$base" ] || [ -z "$key" ] || [ -z "$model" ]; then
    echo "⚠️ 配置不完整，请先执行: xcodeaiproxy setup"
    exit 1
  fi

  if ! validate_base_url "$base"; then
    echo "❌ OPENAI_BASE_URL 格式不正确: $base"
    echo "对策: 执行 xcodeaiproxy setup 重新配置。"
    exit 1
  fi

  if ! validate_api_key "$key"; then
    echo "❌ OPENAI_API_KEY 格式不正确（不能为空、不能有空格、长度至少 8）。"
    echo "对策: 执行 xcodeaiproxy setup 重新配置。"
    exit 1
  fi

  if ! validate_model "$model"; then
    echo "❌ OPENAI_MODEL 格式不正确: $model"
    echo "对策: 执行 xcodeaiproxy setup 重新配置。"
    exit 1
  fi

  if ! validate_port "$port"; then
    echo "❌ PORT 格式不正确: $port"
    echo "对策: 执行 xcodeaiproxy setup 重新配置。"
    exit 1
  fi

  if is_healthy "$port"; then
    echo "ℹ️ xcodeaiproxy 已在运行 (port=$port)"
    exit 0
  fi

  echo "🚀 后台启动 xcodeaiproxy (port=$port)"
  if [ -n "$binary_path" ]; then
    (
      cd "$PROJECT_DIR"
      nohup env PORT="$port" "$binary_path" >"$LOG_FILE" 2>&1 &
      echo $! >"$PID_FILE"
    )
  else
    if ! command -v cargo >/dev/null 2>&1; then
      echo "❌ 未找到可执行二进制，也未安装 cargo。"
      echo "请先执行 cargo build --release，或安装 Rust 工具链。"
      exit 1
    fi
    (
      cd "$PROJECT_DIR"
      nohup env PORT="$port" cargo run >"$LOG_FILE" 2>&1 &
      echo $! >"$PID_FILE"
    )
  fi

  local ok=0
  for _ in {1..50}; do
    if is_healthy "$port"; then
      ok=1
      break
    fi
    sleep 0.2
  done

  if [ "$ok" -eq 1 ]; then
    echo "✅ 启动成功: http://127.0.0.1:$port"
    echo "日志文件: $LOG_FILE"
    exit 0
  fi

  echo "❌ 启动失败，最近日志:"
  tail -n 50 "$LOG_FILE" 2>/dev/null || true
  exit 1
}

stop_cmd() {
  ensure_project
  ensure_env_file
  local port stop_script
  port="$(resolve_port)"
  stop_script="$SCRIPT_DIR/xcodeaiproxy-stop"

  if [ -x "$stop_script" ]; then
    PORT="$port" "$stop_script" "$@"
  elif command -v xcodeaiproxy-stop >/dev/null 2>&1; then
    PORT="$port" xcodeaiproxy-stop "$@"
  else
    echo "❌ 未找到 xcodeaiproxy-stop"
    exit 1
  fi

  if [ -f "$PID_FILE" ]; then
    rm -f "$PID_FILE"
  fi
}

status_cmd() {
  ensure_project
  ensure_env_file
  local port healthy status
  local pid_file_pid pid_file_state
  local listening_pids proxy_pids
  port="$(resolve_port)"

  healthy=0
  if is_healthy "$port"; then
    healthy=1
  fi

  listening_pids=""
  proxy_pids=""
  if command -v lsof >/dev/null 2>&1; then
    local pid cmd
    while IFS= read -r pid; do
      [ -z "$pid" ] && continue

      if [ -n "$listening_pids" ]; then
        listening_pids="$listening_pids $pid"
      else
        listening_pids="$pid"
      fi

      cmd="$(ps -p "$pid" -o command= 2>/dev/null || true)"
      if is_proxy_cmd "$cmd"; then
        if [ -n "$proxy_pids" ]; then
          proxy_pids="$proxy_pids $pid"
        else
          proxy_pids="$pid"
        fi
      fi
    done < <(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)
  fi

  pid_file_pid=""
  pid_file_state="missing"
  if [ -f "$PID_FILE" ]; then
    pid_file_pid="$(head -n 1 "$PID_FILE" | tr -d '[:space:]')"
    if [[ "$pid_file_pid" =~ ^[0-9]+$ ]] && kill -0 "$pid_file_pid" 2>/dev/null; then
      pid_file_state="alive"
    elif [[ "$pid_file_pid" =~ ^[0-9]+$ ]]; then
      pid_file_state="stale"
    else
      pid_file_state="invalid"
    fi
  fi

  status="stopped"
  if [ "$healthy" -eq 1 ] || [ -n "$proxy_pids" ]; then
    status="running"
  fi

  if [ "$status" = "running" ]; then
    echo "✅ 状态: running"
  else
    echo "ℹ️ 状态: stopped"
  fi

  echo "端口: $port"
  if [ "$healthy" -eq 1 ]; then
    echo "健康检查: ok"
  else
    echo "健康检查: fail"
  fi
  echo "访问地址: http://127.0.0.1:$port"

  if [ -n "$proxy_pids" ]; then
    echo "代理进程 PID: $proxy_pids"
  elif [ -n "$listening_pids" ]; then
    echo "监听进程 PID: $listening_pids (非 xcode-ai-proxy-rust)"
  else
    echo "监听进程: 无"
  fi

  case "$pid_file_state" in
    alive)
      echo "PID 文件: $PID_FILE (有效: $pid_file_pid)"
      ;;
    stale)
      echo "PID 文件: $PID_FILE (已失效: $pid_file_pid)"
      ;;
    invalid)
      echo "PID 文件: $PID_FILE (内容无效)"
      ;;
    *)
      echo "PID 文件: $PID_FILE (不存在)"
      ;;
  esac

  echo "配置文件: $ENV_FILE"
  echo "日志文件: $LOG_FILE"

  if [ "$status" = "running" ]; then
    echo "停止命令: xcodeaiproxy-stop"
  fi
}

logs_cmd() {
  if [ ! -f "$LOG_FILE" ]; then
    echo "ℹ️ 暂无日志: $LOG_FILE"
    exit 0
  fi
  tail -n 100 -f "$LOG_FILE"
}

run_cmd() {
  ensure_project
  ensure_env_file
  local binary_path
  binary_path="$(find_binary || true)"
  cd "$PROJECT_DIR"
  if [ -n "$binary_path" ]; then
    exec env PORT="$(resolve_port)" "$binary_path"
  fi

  if [ -x "./start_rust.sh" ]; then
    exec ./start_rust.sh
  fi

  if command -v cargo >/dev/null 2>&1; then
    exec cargo run
  fi

  echo "❌ 无法前台运行：未找到二进制、start_rust.sh 或 cargo。"
  exit 1
}

COMMAND="${1:-start}"
if [ $# -gt 0 ]; then
  shift
fi

case "$COMMAND" in
  start)
    start_cmd "$@"
    ;;
  stop)
    stop_cmd "$@"
    ;;
  restart)
    stop_cmd "$@" || true
    start_cmd "$@"
    ;;
  status)
    status_cmd "$@"
    ;;
  logs)
    logs_cmd "$@"
    ;;
  setup)
    setup_cmd "$@"
    ;;
  run)
    run_cmd "$@"
    ;;
  models)
    show_models_cmd "$@"
    ;;
  use-model)
    use_model_cmd "${1:-}"
    ;;
  doctor)
    doctor_cmd "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
